---
const nav = [
  { href: "/map/", label: "Map", match: ["/map/"] },
  { href: "/collection/", label: "Collection", match: ["/collection/", "/work/", "/lab/"] },
  { href: "/writing/", label: "Writing", match: ["/writing/", "/papers/", "/stories/"] },
  { href: "/about/", label: "About", match: ["/about/"] },
  { href: "/contact/", label: "Contact", match: ["/contact/"] },
];

const path = Astro.url.pathname;
const isActive = (item: (typeof nav)[number]) => item.match.some((m) => path.startsWith(m));
---

<header class="border-b border-faint">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-2 px-5 py-3 sm:h-16 sm:flex-row sm:items-center sm:justify-between sm:py-0"
  >
    <a
      href="/"
      class="wonk text-lg font-semibold tracking-tight transition-colors hover:text-accent"
      style="view-transition-name: wordmark"
    >
      Jake Herridge
    </a>
    <nav aria-label="Primary" class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
      {
        nav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item) ? "page" : undefined}
            class:list={[
              "transition-colors hover:text-accent",
              isActive(item) ? "text-accent" : "text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
