---
const year = new Date().getFullYear();

const links = [
  { href: "https://www.linkedin.com/in/jake-herridge-2722b139", label: "LinkedIn" },
  { href: "https://github.com/jakelherridge", label: "GitHub" },
  { href: "/contact/", label: "Contact" },
  { href: "/ai/", label: "For AI" },
  { href: "/llms.txt", label: "llms.txt" },
];
---

<footer class="mt-24 border-t border-faint">
  <div class="mx-auto max-w-5xl px-5 py-12">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-serif text-base text-ink">Jake Herridge</p>
        <p class="mt-1 text-sm text-muted">Bentonville, Arkansas</p>
      </div>
      <nav aria-label="Elsewhere" class="flex flex-wrap gap-x-5 gap-y-1 text-sm text-muted">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="transition-colors hover:text-accent"
              rel={l.href.startsWith("http") ? "me noopener" : undefined}
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
    <p class="mt-10 text-xs text-muted">
      © {year} Jake Herridge. Built to be read by humans and machines.
    </p>
  </div>
</footer>
