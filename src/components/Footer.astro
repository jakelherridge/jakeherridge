---
import PixelFrog from "./PixelFrog.astro";

const year = new Date().getFullYear();

const links = [
  { href: "https://www.linkedin.com/in/jake-herridge-2722b139", label: "LinkedIn" },
  { href: "https://github.com/jakelherridge", label: "GitHub" },
  { href: "/contact/", label: "Contact" },
  { href: "/ai/", label: "For AI" },
  { href: "/llms.txt", label: "llms.txt" },
];
---

<footer class="relative mt-24 border-t border-faint">
  <PixelFrog />
  <div class="mx-auto max-w-5xl px-5 py-12">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-serif text-base text-ink">Jake Herridge</p>
        <p class="mt-1 text-sm text-muted">Bentonville, Arkansas</p>
      </div>
      <nav aria-label="Elsewhere" class="flex flex-wrap gap-x-5 gap-y-1 text-sm text-muted">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="transition-colors hover:text-accent"
              rel={l.href.startsWith("http") ? "me noopener" : undefined}
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
    <div class="mt-10 flex flex-col gap-1 text-xs text-muted sm:flex-row sm:justify-between">
      <p>© {year} Jake Herridge. Built to be read by humans and machines.</p>
      <p
        title="A moment here is a helek, an old unit of time. 1080 to the hour. I try to spend mine on purpose."
      >
        You have spent <span id="helek-count">1</span>
        <span id="helek-word">moment</span> here.
      </p>
    </div>
  </div>
</footer>

<script>
  // One helek: an old unit of time, 3 and a third seconds. 1080 to the hour.
  const count = document.getElementById("helek-count");
  const word = document.getElementById("helek-word");
  let moments = 1;
  setInterval(() => {
    if (document.hidden || !count || !word) return;
    moments += 1;
    count.textContent = String(moments);
    word.textContent = moments === 1 ? "moment" : "moments";
  }, 3333);
</script>
