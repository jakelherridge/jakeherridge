---
import BaseLayout from "../layouts/BaseLayout.astro";
import GraphMap from "../components/GraphMap.astro";
---

<BaseLayout
  title="The Map"
  description="An interactive map of Jake Herridge: builds, papers, creative work, values, and influences, joined by typed edges. Machine readable at /graph.json."
>
  <section class="mx-auto max-w-5xl px-5 py-14">
    <header class="max-w-2xl">
      <h1 class="wonk text-4xl font-semibold tracking-tight md:text-5xl">The Map</h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Builds, papers, writing, values, influences, and life, joined by typed edges. The same
        structure as Synapse, the knowledge system I keep.
      </p>
      <p class="mt-3 text-muted">
        Click a dot to read it. Drag one to rearrange. Hollow dashed dots did not ship.
      </p>
    </header>

    <div class="mt-8 reveal">
      <GraphMap variant="full" />
    </div>

    <p class="mt-6 font-mono text-xs text-muted">
      Reading this with a machine? The full graph is at{" "}
      <a href="/graph.json" class="text-accent underline underline-offset-4">/graph.json</a>:
      kinds, relations, nodes, and edges.
    </p>
  </section>
</BaseLayout>
