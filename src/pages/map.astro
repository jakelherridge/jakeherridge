---
import BaseLayout from "../layouts/BaseLayout.astro";
import GraphMap from "../components/GraphMap.astro";
---

<BaseLayout
  title="The Map"
  description="An interactive map of Jake Herridge: builds, papers, creative work, values, and influences, joined by typed edges. Machine readable at /graph.json."
>
  <section class="mx-auto max-w-5xl px-5 py-14">
    <header class="max-w-2xl">
      <h1 class="wonk text-4xl font-semibold tracking-tight md:text-5xl">The Map</h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        I keep a private knowledge system that breaks what I learn into small typed nodes joined
        by typed edges. This page turns that idea on its author. The things I have built and
        written, what I value, and the people who shaped it, all on one map.
      </p>
      <p class="mt-3 text-muted">
        Click a dot to read it. Drag one to mess with the layout. The hollow dashed dots never
        shipped. They stay on the map anyway.
      </p>
    </header>

    <div class="mt-8 reveal">
      <GraphMap variant="full" />
    </div>

    <p class="mt-6 font-mono text-xs text-muted">
      Reading this with a machine? The whole graph lives at{" "}
      <a href="/graph.json" class="text-accent underline underline-offset-4">/graph.json</a>, typed
      edges and all.
    </p>
  </section>
</BaseLayout>
