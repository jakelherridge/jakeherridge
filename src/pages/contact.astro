---
import BaseLayout from "../layouts/BaseLayout.astro";
import Email from "../components/Email.astro";
import { person } from "../data/person";

const inputClass =
  "mt-1.5 w-full rounded border border-faint bg-surface px-3 py-2 text-ink placeholder:text-muted";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Jake Herridge about a role, a project, or a problem worth solving."
>
  <section class="mx-auto max-w-2xl px-5 py-16">
    <h1 class="wonk text-4xl font-semibold tracking-tight md:text-5xl">Get in touch</h1>
    <p class="mt-4 text-lg text-muted">
      Hiring, or just want to talk something through? Send a note. I read everything.
    </p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/thanks/"
      class="mt-10 space-y-5"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden" aria-hidden="true">
        <label>Do not fill this out if you are human: <input name="bot-field" /></label>
      </p>
      <div>
        <label for="name" class="block text-sm text-muted">Name</label>
        <input id="name" name="name" type="text" required class={inputClass} />
      </div>
      <div>
        <label for="email" class="block text-sm text-muted">Email</label>
        <input id="email" name="email" type="email" required class={inputClass} />
      </div>
      <div>
        <label for="message" class="block text-sm text-muted">Message</label>
        <textarea id="message" name="message" rows="6" required class={inputClass}></textarea>
      </div>
      <button
        type="submit"
        class="rounded bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-strong"
      >
        Send
      </button>
    </form>

    <div class="mt-12 border-t border-faint pt-8">
      <p class="text-sm text-muted">
        Prefer another way? If the form gives you any trouble, use the email button.
      </p>
      <div class="mt-4 flex flex-wrap items-center gap-5 text-sm">
        <a
          href={person.linkedin}
          rel="me noopener"
          class="text-accent underline underline-offset-4 transition-colors hover:text-accent-strong"
        >
          LinkedIn
        </a>
        <Email />
      </div>
    </div>
  </section>
</BaseLayout>
