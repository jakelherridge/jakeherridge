---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import { specimens, shelved } from "../data/collection";
import { internalWork } from "../data/person";
import { art } from "../data/creative";
---

<BaseLayout
  title="The Collection"
  description="Everything Jake Herridge has made worth showing: apps, systems, sites, art, and the shelved experiments that taught the most."
>
  <section class="mx-auto max-w-5xl px-5 py-14">
    <header class="max-w-2xl">
      <h1 class="wonk text-4xl font-semibold tracking-tight md:text-5xl">The Collection</h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Everything I have made that is worth showing. Each entry gets a number and an honest
        stamp. The shelved ones stay. They paid for the lessons the shipped ones run on.
      </p>
    </header>

    <!-- Shipped and growing -->
    <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2">
      {
        specimens.map((s, i) => (
          <div class="reveal">
            <SpecimenCard specimen={s} tilt={i % 2 === 0 ? "left" : "right"} />
          </div>
        ))
      }
    </div>

    <!-- Inside the business -->
    <section id="inside" class="mt-16 scroll-mt-20 border-t border-faint pt-12">
      <h2 class="wonk text-2xl font-semibold tracking-tight md:text-3xl">
        Built inside the business
      </h2>
      <p class="mt-3 max-w-2xl text-muted">
        Some of this lives inside a company, so I can describe it but not show the screens. No
        numbers on these. You will have to take my word, which is the point of the rest of the
        page.
      </p>
      <dl class="mt-8 grid grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2">
        {
          internalWork.map((w) => (
            <div class="reveal">
              <dt class="font-serif text-lg">{w.name}</dt>
              <dd class="mt-1 text-muted">{w.body}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- Shelved -->
    <section id="shelved" class="mt-16 scroll-mt-20 border-t border-faint pt-12">
      <div class="flex items-center gap-4">
        <h2 class="wonk text-2xl font-semibold tracking-tight md:text-3xl">The shelved drawer</h2>
        <span class="stamp stamp-shelved">shelved</span>
      </div>
      <p class="mt-3 max-w-2xl text-muted">
        Not failures. Tuition. Each one comes with the field note I actually wrote down after.
      </p>
      <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          shelved.map((e) => (
            <article class="reveal rounded-md border border-dashed border-rust/40 bg-surface p-5">
              <p class="font-mono text-[0.68rem] tracking-wide text-muted">No. {e.no}</p>
              <h3 class="mt-2 font-serif text-xl tracking-tight">{e.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted">
                <span class="font-mono text-[0.65rem] uppercase tracking-widest text-rust">
                  Field note
                </span>
                <br />
                {e.lesson}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- The art shelf -->
    <section id="art" class="mt-16 scroll-mt-20 border-t border-faint pt-12">
      <h2 class="wonk text-2xl font-semibold tracking-tight md:text-3xl">Made for the joy of it</h2>
      <p class="mt-3 max-w-2xl text-muted">
        Not everything I make is useful, and that is deliberate. A few pieces from the shelf.
      </p>
      <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {
          art.map((a) => (
            <figure
              id={a.id}
              class="reveal scroll-mt-20 overflow-hidden rounded-md border border-faint bg-surface"
            >
              <Image
                src={a.image}
                alt={a.alt}
                widths={[420, 640, 840]}
                sizes="(max-width: 640px) 92vw, 320px"
                format="webp"
                class="aspect-[4/3] w-full object-cover"
              />
              <figcaption class="p-5">
                <p class="font-mono text-[0.65rem] uppercase tracking-widest text-rust">
                  {a.category}
                </p>
                <h3 class="mt-1 font-serif text-lg tracking-tight">{a.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted">{a.blurb}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
      <p class="mt-6 text-sm text-muted">
        The written ones live over in
        <a
          href="/writing/"
          class="text-accent underline underline-offset-4 hover:text-accent-strong">Writing</a
        >.
      </p>
    </section>
  </section>
</BaseLayout>
