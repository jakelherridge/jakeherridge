---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Thank you" description="Your message is on its way to Jake Herridge.">
  <section class="mx-auto max-w-2xl px-5 py-28 text-center">
    <h1 class="font-serif text-4xl tracking-tight md:text-5xl">Thank you.</h1>
    <p class="mx-auto mt-4 max-w-md text-lg text-muted">
      Your message is in. I read everything, and I will get back to you.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-strong"
    >
      Back home
    </a>
  </section>
</BaseLayout>
