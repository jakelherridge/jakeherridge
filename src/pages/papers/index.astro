---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const papers = (await getCollection("papers", (p) => p.data.status === "published")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", timeZone: "UTC" });
---

<BaseLayout
  title="White Papers"
  description="Practitioner white papers on bringing AI into real business work, by Jake Herridge."
>
  <section class="mx-auto max-w-2xl px-5 py-16">
    <header class="border-b border-faint pb-8">
      <h1 class="wonk text-3xl font-semibold leading-[1.08] tracking-tight md:text-5xl">
        White papers
      </h1>
      <p class="mt-4 text-lg text-muted">
        Practitioner pieces on bringing AI into real business work.
      </p>
    </header>

    {
      papers.length === 0 ? (
        <p class="mt-12 text-muted">The first papers are on their way.</p>
      ) : (
        <ul class="mt-2 divide-y divide-faint">
          {papers.map((paper) => (
            <li class="py-7">
              <a href={`/papers/${paper.id}/`} class="group block">
                <div class="flex items-baseline justify-between gap-4">
                  <h2 class="font-serif text-xl tracking-tight transition-colors group-hover:text-accent md:text-2xl">
                    {paper.data.title}
                  </h2>
                  <time
                    datetime={paper.data.date.toISOString()}
                    class="shrink-0 font-mono text-xs text-muted"
                  >
                    {fmt(paper.data.date)}
                  </time>
                </div>
                <p class="mt-2 text-muted">{paper.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
