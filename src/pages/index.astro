---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import GraphMap from "../components/GraphMap.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import { specimens } from "../data/collection";
import { getCollection } from "astro:content";
import professional from "../assets/jake-professional.jpg";
import candid from "../assets/jake-candid.jpg";

const name = "Jake Herridge";
let letterIndex = 0;
const words = name.split(" ").map((word) => word.split("").map((ch) => ({ ch, i: letterIndex++ })));

const featured = ["pocketwild", "synapse", "apd"]
  .map((id) => specimens.find((s) => s.id === id)!)
  .filter(Boolean);

const papers = (await getCollection("papers", (p) => p.data.status === "published")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const desk = [
  ...papers.map((p) => ({
    href: `/papers/${p.id}/`,
    kind: "White paper",
    title: p.data.title,
    blurb: p.data.description,
  })),
  {
    href: "/stories/the-boy-and-the-sword/",
    kind: "A story",
    title: "The Boy and the Sword",
    blurb: "A boy loses his magic sword and learns to fry his own egg.",
  },
];
---

<BaseLayout
  title="Jake Herridge"
  description="Jake Herridge: father, engineer, nerd, AI guy, wannabe philosopher. Bentonville, Arkansas. An iOS app, a knowledge graph, white papers on AI in real business work, stories, and art."
>
  <!-- Front door -->
  <section class="mx-auto max-w-5xl px-5 pt-14 pb-16 md:pt-20">
    <div class="grid items-center gap-10 md:grid-cols-[7fr_5fr]">
      <div>
        <h1
          class="wonk kinetic text-5xl font-semibold leading-[1.03] tracking-tight md:text-7xl"
          aria-label={name}
        >
          {
            words.map((letters, w) => (
              <>
                {w > 0 && " "}
                <span class="inline-block whitespace-nowrap" aria-hidden="true">
                  {letters.map(({ ch, i }) => (
                    <span class="kl" style={`--i:${i}`}>{ch}</span>
                  ))}
                </span>
              </>
            ))
          }
        </h1>
        <p class="enter mt-5 font-serif text-xl leading-snug text-ink md:text-2xl" style="--enter-step: 4">
          Father, engineer, nerd, AI guy, wannabe philosopher.
        </p>
        <p class="enter mt-3 max-w-xl text-lg leading-relaxed text-muted" style="--enter-step: 6">
          I live in Bentonville, Arkansas, and I like making things. This site is where I keep
          them.
        </p>
      </div>
      {/* Two photos, polished and real. */}
      <div class="enter relative mx-auto w-full max-w-[280px] md:mx-0 md:max-w-none" style="--enter-step: 3">
        <Image
          src={professional}
          alt="Jake Herridge"
          widths={[360, 540, 720]}
          sizes="(max-width: 768px) 280px, 360px"
          format="webp"
          class="w-full rounded-md border border-faint object-cover shadow-sm"
        />
        <Image
          src={candid}
          alt="Jake Herridge outdoors"
          widths={[200, 320]}
          sizes="150px"
          format="webp"
          class="absolute -bottom-5 -left-5 w-[42%] -rotate-2 rounded-md border-4 border-paper object-cover shadow-md"
        />
      </div>
    </div>
  </section>

  <!-- The Map -->
  <section class="mx-auto max-w-5xl px-5 pb-16">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <h2 class="wonk text-2xl font-semibold tracking-tight md:text-3xl">The Map</h2>
      <a
        href="/map/"
        class="text-sm text-accent underline underline-offset-4 hover:text-accent-strong"
      >
        Open the full map &rarr;
      </a>
    </div>
    <p class="mt-2 max-w-2xl text-muted">
      Builds, papers, values, and people, joined by typed edges.
    </p>
    <div class="reveal mt-6">
      <GraphMap variant="embed" />
    </div>
  </section>

  <!-- From the Collection -->
  <section class="border-y border-faint bg-surface">
    <div class="mx-auto max-w-5xl px-5 py-14">
      <div class="flex flex-wrap items-baseline justify-between gap-3">
        <h2 class="wonk text-2xl font-semibold tracking-tight md:text-3xl">From the Collection</h2>
        <a
          href="/collection/"
          class="text-sm text-accent underline underline-offset-4 hover:text-accent-strong"
        >
          The whole collection &rarr;
        </a>
      </div>
      <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          featured.map((s, i) => (
            <div class="reveal">
              <SpecimenCard specimen={s} tilt={i % 2 === 0 ? "left" : "right"} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- From the desk -->
  <section class="mx-auto max-w-5xl px-5 py-16 pb-24">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <h2 class="wonk text-2xl font-semibold tracking-tight md:text-3xl">From the desk</h2>
      <a
        href="/writing/"
        class="text-sm text-accent underline underline-offset-4 hover:text-accent-strong"
      >
        All the writing &rarr;
      </a>
    </div>
    <ul class="mt-4 divide-y divide-faint">
      {
        desk.map((d) => (
          <li class="reveal">
            <a href={d.href} class="group flex items-baseline justify-between gap-6 py-5">
              <div>
                <p class="font-mono text-[0.62rem] uppercase tracking-widest text-muted">
                  {d.kind}
                </p>
                <h3 class="mt-0.5 font-serif text-xl tracking-tight transition-colors group-hover:text-accent">
                  {d.title}
                </h3>
                <p class="mt-1 text-sm text-muted">{d.blurb}</p>
              </div>
              <span
                aria-hidden="true"
                class="shrink-0 text-accent transition-transform group-hover:translate-x-1"
              >
                &rarr;
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
