---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import professional from "../assets/jake-professional.jpg";
import candid from "../assets/jake-candid.jpg";

const pillars = [
  {
    href: "/papers/",
    title: "White papers",
    body: "Longer thinking, mostly about AI and how real work changes when you bring it in.",
  },
  {
    href: "/work/",
    title: "Builds",
    body: "Things I have made. A wildlife app, a handful of tools, a few that found an audience.",
  },
  {
    href: "/lab/",
    title: "The Lab",
    body: "The workshop. Half-built ideas, the ones that shipped, and the flops I learned the most from.",
  },
];
---

<BaseLayout
  title="Jake Herridge"
  description="Jake Herridge is a builder and writer. An iOS app, internal tools, a stack of white papers, and a real excitement about how much one curious person can make right now."
>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-5 pt-14 pb-20 md:pt-24">
    <div class="grid items-center gap-10 md:grid-cols-[1.5fr_1fr]">
      <div>
        <h1 class="font-serif text-4xl leading-[1.04] tracking-tight md:text-6xl">
          I build things. Lately it feels like anything is buildable.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted md:text-xl">
          I came up in operations, learning how real work gets done. Now I mostly make things and
          write about it. Apps, tools, essays, the occasional flop.
        </p>
        <a
          href="/contact/"
          class="mt-8 inline-flex items-center rounded bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-strong"
        >
          Get in touch
        </a>
      </div>
      {/* Two photos, played against each other: polished and real. */}
      <div class="relative mx-auto w-full max-w-[280px] md:mx-0 md:max-w-none">
        <Image
          src={professional}
          alt="Jake Herridge"
          widths={[360, 540, 720]}
          sizes="(max-width: 768px) 280px, 360px"
          format="webp"
          class="w-full rounded-md border border-faint object-cover shadow-sm"
        />
        <Image
          src={candid}
          alt="Jake Herridge outdoors"
          widths={[200, 320]}
          sizes="150px"
          format="webp"
          class="absolute -bottom-5 -left-5 w-[42%] rounded-md border-4 border-paper object-cover shadow-md"
        />
      </div>
    </div>
  </section>

  <!-- Why I build -->
  <section class="border-y border-faint bg-surface">
    <div class="mx-auto max-w-3xl px-5 py-16 md:py-20">
      <p class="font-serif text-2xl leading-snug tracking-tight md:text-3xl">
        For most of history, building something real took a team, a budget, and a yes from someone
        above you. Not anymore.
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
        One curious person with the right tools can make almost anything now. That is the part I
        cannot get over, and most of what I do is just me chasing it. I built an iOS app without
        writing the code. I have shipped tools that handed people their afternoons back. I write
        because I finally have something I want to say.
      </p>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">
        The thread through all of it is simple. Get the boring work off people, so they can do the
        part that needs a human.
      </p>
    </div>
  </section>

  <!-- Explore -->
  <section class="mx-auto max-w-5xl px-5 py-16">
    <h2 class="font-serif text-2xl tracking-tight md:text-3xl">Have a look around</h2>
    <ul class="mt-6 divide-y divide-faint border-t border-faint">
      {
        pillars.map((p) => (
          <li>
            <a href={p.href} class="group flex items-baseline justify-between gap-6 py-6">
              <div>
                <h3 class="font-serif text-xl tracking-tight transition-colors group-hover:text-accent md:text-2xl">
                  {p.title}
                </h3>
                <p class="mt-1 text-muted">{p.body}</p>
              </div>
              <span
                aria-hidden="true"
                class="shrink-0 text-accent transition-transform group-hover:translate-x-1"
              >
                &rarr;
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Closing -->
  <section class="mx-auto max-w-5xl px-5 pb-24">
    <div class="rounded border border-faint bg-surface px-6 py-12 text-center sm:py-14">
      <h2 class="font-serif text-2xl tracking-tight md:text-3xl">Building something good?</h2>
      <p class="mx-auto mt-3 max-w-xl text-muted">
        Tell me about it. I am always up for a good problem, even just to think it through together.
      </p>
      <a
        href="/contact/"
        class="mt-7 inline-flex items-center rounded bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-strong"
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>
