---
import BaseLayout from "../layouts/BaseLayout.astro";

const linkedin = "https://www.linkedin.com/in/jake-herridge-2722b139";
const github = "https://github.com/jakelherridge";

// The shelf: books that shaped how I think, one line each.
const shelf = [
  {
    title: "Man's Search for Meaning",
    author: "Viktor Frankl",
    take: "A why that can carry any how.",
    color: "#1b1a17",
    h: 11,
  },
  {
    title: "Build",
    author: "Tony Fadell",
    take: "Make the painkiller, not the vitamin.",
    color: "#1f6b54",
    h: 9.5,
  },
  {
    title: "Finite and Infinite Games",
    author: "James Carse",
    take: "Finite games end. Infinite games continue.",
    color: "#a97e2f",
    h: 10.5,
  },
  {
    title: "The Messy Middle",
    author: "Scott Belsky",
    take: "The messy middle is the actual job.",
    color: "#9c4a2c",
    h: 9,
  },
  {
    title: "Psycho-Cybernetics",
    author: "Maxwell Maltz",
    take: "The story you tell about yourself can be rewritten.",
    color: "#31506b",
    h: 10,
  },
  {
    title: "Range",
    author: "David Epstein",
    take: "Range beats a head start.",
    color: "#7a6a56",
    h: 8.5,
  },
  {
    title: "The Infinite Game",
    author: "Simon Sinek",
    take: "Play to keep playing.",
    color: "#164f3e",
    h: 9.8,
  },
];
---

<BaseLayout
  title="About"
  description="Jake Herridge is a builder and writer in Bentonville, Arkansas. Operations background, an engineering degree and an MBA, and a habit of making things: apps, tools, papers, stories, and art."
>
  <section class="mx-auto max-w-2xl px-5 py-16">
    <h1 class="wonk text-4xl font-semibold tracking-tight md:text-5xl">Hi, I'm Jake.</h1>

    <div class="paper-body mt-8">
      <p>
        I am a builder. That is the simplest true thing I can say about myself. I have always taken
        things apart to see how they work, and these days I spend most of my spare hours putting new
        things together.
      </p>
      <p>
        I came up in operations. I spent years learning how real work actually gets done, and where
        it quietly breaks. It turned out to be the best training I could have asked for. The
        interesting problems are almost never the ones on the slide. They are buried in the day to
        day, in the parts everyone has stopped looking at.
      </p>
      <p>
        Here is what I cannot get over. For most of history, building something real took a team and
        a budget and someone's permission. That is over. One curious person with the right tools can
        make almost anything now. I built an iOS app without writing the code myself. I have shipped
        tools that handed people their afternoons back. I am writing a stack of white papers because
        I finally have something I want to say. None of that was within reach for someone like me a
        few years ago, and I am still a little stunned by it.
      </p>
      <p>
        So I build. A lot of it is small. Some of it works. Plenty of it has flopped, and I am
        genuinely fine with that, because every dead end taught me something I used on the next
        thing. I would rather make ten honest attempts than sit around waiting for the perfect one.
      </p>
      <p>
        Underneath all of it, the thing I care about most is helping people get the boring work off
        their plate, so they can spend their time on the part that actually needs a person. That is
        the thread. It runs through the apps, the tools, and the writing alike.
      </p>
      <p>
        When I am not building, I am home in Bentonville, Arkansas, with my wife and our four kids.
        That is the center of it all. The rest is just me chasing the things I think are worth
        making, and trying to learn out loud while I do.
      </p>
    </div>

    <section class="mt-14" aria-label="The shelf: books that shaped me">
      <h2 class="wonk text-2xl font-semibold tracking-tight md:text-3xl">The shelf</h2>
      <p class="mt-2 text-muted">
        The books that shaped how I think. Hover a spine, or press one, for the line I kept.
      </p>
      <ul class="shelf reveal" data-shelf>
        {
          shelf.map((b, i) => (
            <li>
              <button
                type="button"
                class="spine"
                style={`--spine-color:${b.color}; --spine-h:${b.h}rem; --spine-i:${i}`}
                data-take={`"${b.take}" That is what I kept from ${b.title} by ${b.author}.`}
                aria-label={`${b.title} by ${b.author}. ${b.take}`}
              >
                <span class="spine-title">{b.title}</span>
              </button>
            </li>
          ))
        }
      </ul>
      <p class="shelf-take font-serif text-lg italic text-muted" data-shelf-take aria-live="polite">
        Seven spines, one line each.
      </p>
    </section>

    <dl
      class="mt-12 grid grid-cols-1 gap-x-8 gap-y-5 border-t border-faint pt-8 text-sm sm:grid-cols-2"
    >
      <div>
        <dt class="text-muted">Background</dt>
        <dd class="mt-1">Electrical engineer with an MBA, both from Harding. A decade in operations.</dd>
      </div>
      <div>
        <dt class="text-muted">Always learning</dt>
        <dd class="mt-1">Lately, deep in Anthropic's AI Fluency and agent-building courses.</dd>
      </div>
      <div>
        <dt class="text-muted">Based in</dt>
        <dd class="mt-1">Bentonville, Arkansas</dd>
      </div>
      <div>
        <dt class="text-muted">Find me</dt>
        <dd class="mt-1">
          <a href={linkedin} rel="me noopener" class="text-accent underline underline-offset-4 hover:text-accent-strong">LinkedIn</a>,
          <a href={github} rel="me noopener" class="text-accent underline underline-offset-4 hover:text-accent-strong">GitHub</a>
        </dd>
      </div>
    </dl>

    <div class="mt-12">
      <a
        href="/contact/"
        class="inline-flex items-center rounded bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-strong"
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .shelf {
    margin: 2rem 0 0;
    padding: 0 0.4rem;
    list-style: none;
    display: flex;
    align-items: flex-end;
    gap: 0.45rem;
    border-bottom: 3px solid var(--color-ink);
  }
  .spine {
    display: block;
    writing-mode: vertical-rl;
    height: var(--spine-h);
    width: clamp(1.7rem, 6vw, 2.4rem);
    border: 0;
    border-radius: 3px 3px 0 0;
    background: var(--spine-color);
    color: var(--color-paper);
    font-family: var(--font-serif);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    padding: 0.7rem 0;
    cursor: pointer;
    text-align: left;
    transition:
      translate 0.18s ease,
      rotate 0.18s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .spine:hover,
    .spine:focus-visible {
      translate: 0 -7px;
      rotate: -1.5deg;
    }
  }
  .spine-title {
    display: inline-block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-height: 100%;
  }
  .shelf-take {
    margin-top: 1rem;
    min-height: 3.2rem;
  }
</style>

<script>
  const takeEl = document.querySelector<HTMLElement>("[data-shelf-take]");
  document.querySelectorAll<HTMLButtonElement>(".spine").forEach((spine) => {
    const show = () => {
      if (takeEl) takeEl.textContent = spine.dataset.take ?? "";
    };
    spine.addEventListener("pointerenter", show);
    spine.addEventListener("focus", show);
    spine.addEventListener("click", show);
  });
</script>
