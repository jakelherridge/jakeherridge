---
import BaseLayout from "./BaseLayout.astro";
import { person } from "../data/person";
import { techArticle, breadcrumb } from "../lib/schema";

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  slug: string;
}

const { title, description, date, updated, slug } = Astro.props;

const url = `${person.url}/papers/${slug}/`;
const jsonLd = [
  techArticle({ title, description, date, updated, url, pdfUrl: `${person.url}/papers/${slug}.pdf` }),
  breadcrumb([
    { name: "Home", url: `${person.url}/` },
    { name: "White papers", url: `${person.url}/papers/` },
    { name: title, url },
  ]),
];

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="mx-auto max-w-2xl px-5 py-16">
    <header class="border-b border-faint pb-8">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">White paper</p>
      <h1 class="mt-3 font-serif text-3xl leading-[1.1] tracking-tight md:text-5xl">
        {title}
      </h1>
      <p class="mt-4 font-serif text-lg italic leading-snug text-muted md:text-xl">
        {description}
      </p>
      <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-muted">
        <span class="text-ink">Jake Herridge</span>
        <time datetime={date.toISOString()}>{fmt(date)}</time>
        {updated && <span>Updated {fmt(updated)}</span>}
      </div>
      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a
          href={`/papers/${slug}.pdf`}
          class="text-accent underline underline-offset-4 transition-colors hover:text-accent-strong"
        >
          Download PDF
        </a>
        <a
          href={`/papers/${slug}.md`}
          class="text-accent underline underline-offset-4 transition-colors hover:text-accent-strong"
        >
          View as Markdown
        </a>
      </div>
    </header>
    <div class="paper-body mt-10">
      <slot />
    </div>
  </article>
</BaseLayout>
